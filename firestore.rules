rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidUser() {
      return incoming().keys().hasAll(['email', 'createdAt']) 
        && incoming().keys().size() == 2
        && incoming().email is string
        && incoming().createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() 
        && request.auth.uid == userId 
        && isValidUser()
        && (incoming().email == request.auth.token.email || !('email' in request.auth.token) || incoming().email == null)
        && incoming().createdAt == request.time;
      allow update: if false; // Immutable
    }

    function isValidDoc() {
      return incoming().keys().hasAll(['userId', 'name', 'fileUri', 'mimeType', 'category', 'createdAt'])
        && incoming().keys().size() == 6
        && incoming().userId is string
        && incoming().name is string
        && incoming().name.size() > 0 && incoming().name.size() <= 200
        && incoming().fileUri is string
        && incoming().fileUri.size() <= 1000
        && incoming().mimeType is string
        && incoming().mimeType.size() <= 100
        && incoming().category is string
        && incoming().category.size() <= 100
        && incoming().createdAt is timestamp;
    }

    match /documents/{documentId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && isValidDoc()
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    function isValidChatSession() {
      return incoming().keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt'])
        && incoming().keys().size() == 4
        && incoming().userId is string
        && incoming().title is string
        && incoming().title.size() > 0 && incoming().title.size() <= 200
        && incoming().createdAt is timestamp
        && incoming().updatedAt is timestamp;
    }

    match /chatSessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated()
        && isValidChatSession()
        && incoming().userId == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
      allow update: if isAuthenticated()
        && isValidChatSession()
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'updatedAt']);
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      function isSessionOwner() {
        return get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId == request.auth.uid;
      }
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && isSessionOwner();
        allow list: if isAuthenticated() && isSessionOwner();
        allow create: if isAuthenticated()
          && isSessionOwner()
          && incoming().keys().hasAll(['userId', 'role', 'text', 'createdAt'])
          && incoming().keys().size() == 4
          && incoming().userId is string
          && incoming().userId == request.auth.uid
          && incoming().userId == get(/databases/$(database)/documents/chatSessions/$(sessionId)).data.userId
          && incoming().role in ['user', 'ai']
          && incoming().text is string
          && incoming().text.size() <= 50000
          && incoming().createdAt == request.time;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
