{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the HR Copilot.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["email", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "description": "A document uploaded by a user for context.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "fileUri": { "type": "string" },
        "mimeType": { "type": "string" },
        "category": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "name", "fileUri", "mimeType", "category", "createdAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A user's chat session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Messages inside a chat session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "role", "text", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection."
    },
    "documents/{documentId}": {
      "schema": { "$ref": "#/entities/Document" },
      "description": "Uploaded documents."
    },
    "chatSessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Chat sessions container."
    },
    "chatSessions/{sessionId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/ChatMessage" },
      "description": "Messages in the session."
    }
  }
}
